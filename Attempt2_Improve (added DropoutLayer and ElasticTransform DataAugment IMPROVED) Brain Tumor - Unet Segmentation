rizontalFlip(p=0.5),\n","#     A.VerticalFlip(p=0.5),\n","#     A.RandomRotate90(p=0.5),\n","#     A.ShiftScaleRotate(shift_limit=0.05, scale_limit=0.05, rotate_limit=15, p=0.5),\n","#     A.RandomBrightnessContrast(p=0.2),\n","# ], additional_targets={'mask': 'mask'})\n","\n","\n","augmentation = A.Compose([\n","    # Geometric transformations (spatial)\n","    A.HorizontalFlip(p=0.5),\n","    A.VerticalFlip(p=0.5),\n","    A.RandomRotate90(p=0.5),\n","    A.ShiftScaleRotate(shift_limit=0.05, scale_limit=0.05, rotate_limit=15, p=0.5),\n","    A.ElasticTransform(alpha=1, sigma=10, interpolation=cv2.INTER_CUBIC, p=0.5, noise_distribution=\"gaussian\"), # Added elastic deformation (MOST IMPORTANT, referened/used in Unet paper)\n","\n","    # Pixel-level transformations (intensity/color)\n","    A.RandomBrightnessContrast(p=0.2), # Increased probability\n","    # A.GaussNoise(p=0.2), # Added noise\n","    # A.GaussianBlur(p=0.2), # Added blur\n","\n","    # # Occlusion augmentation\n","    # A.CoarseDropout(max_holes=8, max_height=8, max_width=8, p=0.2),\n","], additional_targets={'mask': 'mask'})\n"],"metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-06-30T14:09:59.214628Z","iopub.execute_input":"2025-06-30T14:09:59.214807Z","iopub.status.idle":"2025-06-30T14:10:10.009317Z","shell.execute_reply.started":"2025-06-30T14:09:59.214793Z","shell.execute_reply":"2025-06-30T14:10:10.008392Z"},"id":"jzDwwxw0p9py"},"outputs":[],"execution_count":null},{"cell_type":"code","source":["def augment_image_and_mask(image, mask):\n","    augmented = augmentation(image=image, mask=mask)\n","    return augmented['image'], augmented['mask']\n","\n","img_id = train_coco.getImgIds()[0]\n","image, mask = load_image_and_mask(train_coco, train_dir, img_id)\n","\n","\n","aug_img, aug_mask = augment_image_and_mask(image, mask)\n","\n","\n","import matplotlib.pyplot as plt\n","\n","fig, axes = plt.subplots(2, 2, figsize=(10, 10))\n","axes[0,0].imshow(image); axes[0,0].set_title('Original Image'); axes[0,0].axis('off')\n","axes[0,1].imshow(mask, cmap='gray'); axes[0,1].set_title('Original Mask'); axes[0,1].axis('off')\n","axes[1,0].imshow(aug_img); axes[1,0].set_title('Augmented Image'); axes[1,0].axis('off')\n","axes[1,1].imshow(aug_mask, cmap='gray'); axes[1,1].set_title('Augmented Mask'); axes[1,1].axis('off')\n","plt.show()\n"],"metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-06-30T14:10:10.010834Z","iopub.execute_input":"2025-06-30T14:10:10.011115Z","iopub.status.idle":"2025-06-30T14:10:10.514918Z","shell.execute_reply.started":"2025-06-30T14:10:10.011097Z","shell.execute_reply":"2025-06-30T14:10:10.514195Z"},"id":"ZLgmirCdp9py","colab":{"base_uri":"https://localhost:8080/","height":829},"executionInfo":{"status":"ok","timestamp":1762829893871,"user_tz":360,"elapsed":546,"user":{"displayName":"Ramin","userId":"13888829111192401974"}},"outputId":"6f3777e7-ab13-4eae-e363-37e7c34926d7"},"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x1000 with 4 Axes>"],"image/png":"\n"},"metadata":{}}],"execution_count":null},{"cell_type":"code","source":["import cv2\n","import numpy as np\n","\n","def preprocess_image_and_mask(image, mask, img_size=(128, 128)):\n","\n","    if image.ndim == 3 and image.shape[-1] == 3:\n","        image = cv2.cvtColor(image, cv2.COLOR_RGB2GRAY)  # or BGR2GRAY depending on cv2.imread -> IMAGES are converted to Gray Scale (channel goes from color (3) to gray (1))\n","\n","    image = cv2.resize(image, img_size)\n","    mask = cv2.resize(mask, img_size, interpolation=cv2.INTER_NEAREST)\n","\n","    image = image / 255.0                # normalize pixel values (0-255) to grayscale (0-1)\n","    mask = (mask > 0).astype(np.float32) # create binary masks (0 and 1s)\n","\n","    # Add channel dims\n","    image = np.expand_dims(image, axis=-1)\n","    mask = np.expand_dims(mask, axis=-1)\n","\n","    return image, mask\n","\n","\n","\n","\n","def augment_image_and_mask(image, mask):\n","\n","    augmented = augmentation(image=image, mask=mask)\n","    return augmented['image'], augmented['mask']\n","\n","\n"],"metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-06-30T14:12:59.757285Z","iopub.execute_input":"2025-06-30T14:12:59.757851Z","iopub.status.idle":"2025-06-30T14:12:59.763183Z","shell.execute_reply.started":"2025-06-30T14:12:59.757827Z","shell.execute_reply":"2025-06-30T14:12:59.762527Z"},"id":"jKSOqFcRp9pz"},"outputs":[],"execution_count":null},{"cell_type":"code","source":["def data_generator(coco, image_dir, batch_size=16, augment_func=None, img_size=(128,128)):\n","    img_ids = coco.getImgIds()\n","    n = len(img_ids)\n","    while True:\n","        np.random.shuffle(img_ids)\n","        for i in range(0, n, batch_size):\n","            batch_ids = img_ids[i:i+batch_size]\n","            images = []\n","            masks = []\n","            for img_id in batch_ids:\n","                img, mask = load_image_and_mask(coco, image_dir, img_id)\n","                if augment_func:\n","                    img, mask = augment_func(img, mask)\n","                img, mask = preprocess_image_and_mask(img, mask, img_size)\n","                images.append(img)\n","                masks.append(mask)\n","            yield np.array(images, dtype=np.float32), np.array(masks, dtype=np.float32)\n","\n"],"metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-06-30T14:24:03.069158Z","iopub.execute_input":"2025-06-30T14:24:03.069481Z","iopub.status.idle":"2025-06-30T14:24:03.075568Z","shell.execute_reply.started":"2025-06-30T14:24:03.069459Z","shell.execute_reply":"2025-06-30T14:24:03.074872Z"},"id":"tGkYmjlEp9pz"},"outputs":[],"execution_count":null},{"cell_type":"code","source":["# my improved version of model architecture\n","from tensorflow.keras import layers, models\n","\n","def build_unet(input_shape=(128, 128, 1)):   # Notice 2D UNET (but working with CT images, not sure if masks across slices are the same, idk how CT 3D aspect handled)\n","    inputs = layers.Input(input_shape)\n","\n","    # --- Encoder ---\n","    \"\"\"\n","    Unet downsampling / \"contracting path\" block, below from Unet paper\n","    - \"The contracting path follows the typical architecture of a convolutional\n","      network. It consists of the repeated application of\n","        - two 3x3 convolutions (unpadded convolutions),\n","        each followed by a rectified linear unit (ReLU)\n","        - and a 2x2 max pooling operation with stride 2 for downsampling.\n","        - At each downsampling step we double the number of feature channels\"\n","    - Unet paper uses 4 downsampling blocks with first block starting with out_features=64\n","\n","    Tensorflow Conv2D\n","    https://www.tensorflow.org/api_docs/python/tf/keras/layers/Conv2D\n","    - first 2 params seen below for each conv is filter (outputfeaturesize) and kernel size , if kernel_size=3, then its a 3x3 kernel\n","    - note in tensorflow, activation='relu' flag performs relu after\n","    - padding: \"valid\" means no padding\n","    \"\"\"\n","    padding = 'same' # 'same' or 'valid'\n","\n","    # note input seems to be (height, width, features)=(128, 128, 1)\n","    # so this first Conv makes the features go from 1 to 64, then after each block, doubles the number of features\n","    c1 = layers.Conv2D(64, 3, activation='relu', padding=padding)(inputs)\n","    c1 = layers.Conv2D(64, 3, activation='relu', padding=padding)(c1)\n","    p1 = layers.MaxPooling2D(pool_size=(2, 2), strides=2)(c1)\n","\n","    c2 = layers.Conv2D(128, 3, activation='relu', padding=padding)(p1)\n","    c2 = layers.Conv2D(128, 3, activation='relu', padding=padding)(c2)\n","    p2 = layers.MaxPooling2D(pool_size=(2, 2), strides=2)(c2)\n","\n","    c3 = layers.Conv2D(256, 3, activation='relu', padding=padding)(p2)\n","    c3 = layers.Conv2D(256, 3, activation='relu', padding=padding)(c3)\n","    p3 = layers.MaxPooling2D(pool_size=(2, 2), strides=2)(c3)\n","\n","    c4 = layers.Conv2D(512, 3, activation='relu', padding=padding)(p3)\n","    c4 = layers.Conv2D(512, 3, activation='relu', padding=padding)(c4)\n","    p4 = layers.MaxPooling2D(pool_size=(2, 2), strides=2)(c4)\n","\n","    # --- Bottleneck ---\n","    \"\"\"\n","    Between downsampling and upsampling, unet paper has 2 sets of 3x3 conv - Relu pairs where the\n","    first conv doubles the out_features\n","    \"\"\"\n","    p4 = layers.Dropout(0.5)(p4) # dropout (experiment)\n","    c5 = layers.Conv2D(1024, 3, activation='relu', padding=padding)(p4)\n","    c5 = layers.Conv2D(1024, 3, activation='relu', padding=padding)(c5)\n","\n","    # --- Decoder ---\n","    \"\"\"\n","    Every step in the expansive path consists of an upsampling of the\n","    feature map followed by a: (below is one upsampling block)\n","    - 2x2 convolution ( up-convolution ) that halves the number of feature channels,\n","    - a concatenation with the correspondingly cropped feature map from the contracting path (downsampling),\n","    - and two 3x3 convolutions, each followed by a ReLU.\n","    The cropping is necessary due to the loss of border pixels in\n","    every convolution.\n","\n","    (4 upsampling blocks)\n","\n","    - At the final layer a 1x1 convolution is used to map each 64\n","    component feature vector to the desired number of classes.\n","\n","    \"\"\"\n","    u6 = layers.UpSampling2D((2, 2))(c5) # tensorflow upsampling conv has no out_feature option\n","    u6 = layers.concatenate([u6, c4]) # NOTE this is correct, where you concatenate with the output of the 2nd conv layer from the corresponding downsampling block (not output of the maxpool)\n","    c6 = layers.Conv2D(512, 3, activation='relu', padding=padding)(u6)\n","    c6 = layers.Conv2D(512, 3, activation='relu', padding=padding)(c6)\n","\n","    u7 = layers.UpSampling2D((2, 2))(c6)\n","    u7 = layers.concatenate([u7, c3])\n","    c7 = layers.Conv2D(256, 3, activation='relu', padding=padding)(u7)\n","    c7 = layers.Conv2D(256, 3, activation='relu', padding=padding)(c7)\n","\n","    u8 = layers.UpSampling2D((2, 2))(c7)\n","    u8 = layers.concatenate([u8, c2])\n","    c8 = layers.Conv2D(128, 3, activation='relu', padding=padding)(u8)\n","    c8 = layers.Conv2D(128, 3, activation='relu', padding=padding)(c8)\n","\n","    u9 = layers.UpSampling2D((2, 2))(c8)\n","    u9 = layers.concatenate([u9, c1])\n","    c9 = layers.Conv2D(64, 3, activation='relu', padding=padding)(u9)\n","    c9 = layers.Conv2D(64, 3, activation='relu', padding=padding)(c9)\n","\n","    # --- Output ---\n","    \"\"\"\n","    1x1 conv\n","\n","    Note below situations if problem is binary segmentation (this problem is binary segmentation)\n","    or multiclass segmentation\n","\n","    2 labels:\n","    (non_tumor: 0, tumor: 1)\n","\n","    For Binary Segmentation (2 classes: e.g., \"object\" and \"background\")\n","    Output features (channels): 1\n","    Activation: Sigmoid\n","    Loss Function: Binary Cross-Entropy (BCE)\n","    In this setup, the single output channel produces a probability map where each pixel value is a probability\n","    between 0 and 1. A threshold (usually 0.5) is applied to this single value to assign a pixel to one of the two classes.\n","    This is the most efficient and standard way to handle binary segmentation.\n","\n","    For Multi-Class Segmentation (>2 classes: e.g., \"car,\" \"road,\" \"sky\")\n","    Output features (channels): num_classes (e.g., 3 for the example above)\n","    Activation: Softmax\n","    Loss Function: Categorical Cross-Entropy (CCE)\n","    In this scenario, each pixel in the output has a vector of probabilities (one for each class), and the softmax function ensures these probabilities sum to 1. The output channel count must equal the number of classes.\n","\n","    So, for my case of a U-Net with only 2 classes, setting the output features to 1 with a sigmoid activation is the correct and simpler approach.\n","\n","    \"\"\"\n","    outputs = layers.Conv2D(1, 1, activation='sigmoid')(c9)  # out_feature/num_classes=1, 1x1 conv, sigmoid applied bc our problem is a binary classification task (non_tumor: 0, tumor: 1)\n","\n","    model = models.Model(inputs=[inputs], outputs=[outputs])\n","    return model\n"],"metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-06-30T14:22:46.903555Z","iopub.execute_input":"2025-06-30T14:22:46.903829Z","iopub.status.idle":"2025-06-30T14:22:46.914403Z","shell.execute_reply.started":"2025-06-30T14:22:46.903809Z","shell.execute_reply":"2025-06-30T14:22:46.913776Z"},"id":"u0QNOUIep9p0"},"outputs":[],"execution_count":null},{"cell_type":"code","source":["# Original\n","# from tensorflow.keras import layers, models\n","\n","# def build_unet(input_shape=(128, 128, 1)):\n","#     inputs = layers.Input(input_shape)\n","\n","#     # --- Encoder ---\n","#     c1 = layers.Conv2D(64, 3, activation='relu', padding='same')(inputs)\n","#     c1 = layers.Conv2D(64, 3, activation='relu', padding='same')(c1)\n","#     p1 = layers.MaxPooling2D((2, 2))(c1)\n","\n","#     c2 = layers.Conv2D(128, 3, activation='relu', padding='same')(p1)\n","#     c2 = layers.Conv2D(128, 3, activation='relu', padding='same')(c2)\n","#     p2 = layers.MaxPooling2D((2, 2))(c2)\n","\n","#     c3 = layers.Conv2D(256, 3, activation='relu', padding='same')(p2)\n","#     c3 = layers.Conv2D(256, 3, activation='relu', padding='same')(c3)\n","#     p3 = layers.MaxPooling2D((2, 2))(c3)\n","\n","#     c4 = layers.Conv2D(512, 3, activation='relu', padding='same')(p3)\n","#     c4 = layers.Conv2D(512, 3, activation='relu', padding='same')(c4)\n","#     p4 = layers.MaxPooling2D((2, 2))(c4)\n","\n","#     # --- Bottleneck ---\n","#     c5 = layers.Conv2D(1024, 3, activation='relu', padding='same')(p4)\n","#     c5 = layers.Conv2D(1024, 3, activation='relu', padding='same')(c5)\n","\n","#     # --- Decoder ---\n","#     u6 = layers.UpSampling2D((2, 2))(c5)\n","#     u6 = layers.concatenate([u6, c4])\n","#     c6 = layers.Conv2D(512, 3, activation='relu', padding='same')(u6)\n","#     c6 = layers.Conv2D(512, 3, activation='relu', padding='same')(c6)\n","\n","#     u7 = layers.UpSampling2D((2, 2))(c6)\n","#     u7 = layers.concatenate([u7, c3])\n","#     c7 = layers.Conv2D(256, 3, activation='relu', padding='same')(u7)\n","#     c7 = layers.Conv2D(256, 3, activation='relu', padding='same')(c7)\n","\n","#     u8 = layers.UpSampling2D((2, 2))(c7)\n","#     u8 = layers.concatenate([u8, c2])\n","#     c8 = layers.Conv2D(128, 3, activation='relu', padding='same')(u8)\n","#     c8 = layers.Conv2D(128, 3, activation='relu', padding='same')(c8)\n","\n","#     u9 = layers.UpSampling2D((2, 2))(c8)\n","#     u9 = layers.concatenate([u9, c1])\n","#     c9 = layers.Conv2D(64, 3, activation='relu', padding='same')(u9)\n","#     c9 = layers.Conv2D(64, 3, activation='relu', padding='same')(c9)\n","\n","#     # --- Output ---\n","#     outputs = layers.Conv2D(1, 1, activation='sigmoid')(c9)  # Binary mask\n","\n","#     model = models.Model(inputs=[inputs], outputs=[outputs])\n","#     return model\n"],"metadata":{"id":"KVXorsmxMaEw"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["import tensorflow.keras.backend as K\n","\n","def iou_metric(y_true, y_pred, smooth=1e-6):\n","    y_true_f = K.flatten(y_true)\n","    y_pred_f = K.flatten(y_pred)\n","    intersection = K.sum(y_true_f * y_pred_f)\n","    union = K.sum(y_true_f) + K.sum(y_pred_f) - intersection\n","    return (intersection + smooth) / (union + smooth)\n","\n","def dice_coef(y_true, y_pred, smooth=1e-6):\n","    y_true_f = K.flatten(y_true)\n","    y_pred_f = K.flatten(y_pred)\n","    intersection = K.sum(y_true_f * y_pred_f)\n","    return (2. * intersection + smooth) / (K.sum(y_true_f) + K.sum(y_pred_f) + smooth)\n","\n","def dice_loss(y_true, y_pred):\n","    return 1 - dice_coef(y_true, y_pred)\n","\n","\"\"\"\n","Combined Loss for binary segmentation: Dice Loss + Binary Cross-Entropy Loss\n","  - using a weighted sum of Binary Cross-Entropy (BCE) and Dice loss is a widely used and often effective approach for\n","  binary segmentation. This combined loss function is commonly referred to as Combo Loss.\n","\n","  - Binary Cross-Entropy (BCE): BCE is a pixel-wise loss that is effective at penalizing incorrect classifications for every\n","  single pixel. It focuses on local accuracy but can be sensitive to class imbalance, meaning a large background area\n","  might dominate the loss, leading to poor segmentation of smaller objects.\n","\n","  - Dice Loss: Dice loss is a region-based loss that measures the overall overlap between the predicted segmentation mask and\n","  the ground truth (the Dice coefficient). It is better at handling class imbalance because it inherently balances the\n","  contribution of foreground and background pixels by focusing on the relationship between predicted and true positive regions\n","\n","  - By taking a weighted sum, you leverage the benefits of both: BCE helps with general classification and stable gradients,\n","  while Dice loss ensures better overlap, especially for small or imbalanced foreground objects.\n","\"\"\"\n","def combined_loss(y_true, y_pred):\n","    dice = dice_loss(y_true, y_pred)\n","    bce = tf.keras.losses.binary_crossentropy(y_true, y_pred)\n","    return 0.6 * dice + 0.4 * bce"],"metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-06-30T14:31:22.976786Z","iopub.execute_input":"2025-06-30T14:31:22.977343Z","iopub.status.idle":"2025-06-30T14:31:22.984939Z","shell.execute_reply.started":"2025-06-30T14:31:22.977301Z","shell.execute_reply":"2025-06-30T14:31:22.984255Z"},"id":"1hWZJj35p9p1"},"outputs":[],"execution_count":null},{"cell_type":"code","source":["initial_learning_rate = 1e-4\n","optimizer = tf.keras.optimizers.Adam(learning_rate=initial_learning_rate)"],"metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-06-30T14:46:29.960668Z","iopub.execute_input":"2025-06-30T14:46:29.9